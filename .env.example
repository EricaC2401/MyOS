SUPABASE_HOST=db.xxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_DBNAME=postgres
SUPABASE_USER=postgres.xxxx
SUPABASE_PASSWORD=your-password-here
SUPABASE_SSLMODE=require
APP_PASSWORD_HASH=pbkdf2_sha256$390000$replace-with-generated-salt$replace-with-generated-hash
APP_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_SECURE=false
